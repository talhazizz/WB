<!DOCTYPE html>
<html>
<head>
    <title>DOM Example</title>
</head>

<body>

    <h2 id="heading">Welcome</h2>

    <button onclick="changeText()">Click Here</button>

    <script>

        function changeText(){
            document.getElementById("heading").innerHTML =
            "Welcome to JavaScript DOM";
        }

    </script>

</body>
</html>
